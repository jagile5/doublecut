---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Work', href: '/work' },
  { label: 'Services', href: '/services' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const serviceLinks = [
  { label: 'Event Videography', href: '/services#event-videography' },
  { label: 'Aerial & Drone', href: '/services#aerial-drone' },
  { label: 'VFX & CGI', href: '/services#vfx-cgi' },
  { label: 'Photography', href: '/services#photography' },
  { label: 'Design Partners', href: '/services#design-partners' },
];
---

<footer class="grain-overlay py-12 px-6" style="background: linear-gradient(180deg, #1a1a1a 0%, #0f0f0f 100%);">
  <div class="max-w-7xl mx-auto relative z-20">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Logo + tagline -->
      <div class="md:col-span-1">
        <a href="/" class="font-display text-2xl tracking-wider text-white block mb-3">
          DOUBLE CUT STUDIOS
        </a>
        <p class="text-white/60 text-sm font-body">
          Video. Aerial. CGI. Photography.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="font-display text-lg tracking-wider text-white mb-4">Navigation</h4>
        <ul class="space-y-2">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class="text-white/60 text-sm font-body hover:text-[var(--color-primary)] transition-all duration-500 ease-out">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-display text-lg tracking-wider text-white mb-4">Services</h4>
        <ul class="space-y-2">
          {serviceLinks.map(link => (
            <li>
              <a href={link.href} class="text-white/60 text-sm font-body hover:text-[var(--color-primary)] transition-all duration-500 ease-out">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-display text-lg tracking-wider text-white mb-4">Contact</h4>
        <ul class="space-y-2 text-white/60 text-sm font-body">
          <li>
            <a href="mailto:hello@doublecutstudios.com" class="hover:text-[var(--color-primary)] transition-all duration-500 ease-out">
              hello@doublecutstudios.com
            </a>
          </li>
          <li>
            <a href="#" class="hover:text-[var(--color-primary)] transition-all duration-500 ease-out">Instagram</a>
          </li>
          <li>
            <a href="#" class="hover:text-[var(--color-primary)] transition-all duration-500 ease-out">YouTube</a>
          </li>
          <li>
            <a href="#" class="hover:text-[var(--color-primary)] transition-all duration-500 ease-out">LinkedIn</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Copyright + hidden easter egg -->
    <div class="mt-12 pt-6 text-center" style="border-top: 1px solid rgba(255,255,255,0.1)">
      <p class="text-white/40 text-sm font-body">
        &copy; 2025 Double Cut Studios. All rights reserved.
        <span class="footer-easter-egg" aria-hidden="true"> — built with late nights, too much coffee, and a stubborn belief that every frame matters. Kia kaha, Josh.</span>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-easter-egg {
    color: transparent;
    user-select: all;
  }
</style>
