---
import WaveDivider from '../WaveDivider.astro';
---

<section class="py-24 md:py-32 px-6 bg-[var(--color-accent-2)] relative overflow-hidden">
<div class="max-w-4xl mx-auto text-center relative z-10">
<h2 data-animate class="font-display text-5xl md:text-7xl mb-6 text-[var(--color-bg-dark)]">
Ready to Make Something Great?
</h2>
<p data-animate class="font-body text-[var(--color-bg-dark)]/60 text-lg mb-10 max-w-xl mx-auto">
Whether it's a single shoot or a full creative campaign, we'd love to hear about your project.
</p>
<a
href="/contact"
data-animate
class="inline-block px-10 py-4 border-2 border-[var(--color-bg-dark)] text-[var(--color-bg-dark)] font-display text-2xl tracking-wider rounded-full hover:bg-[var(--color-bg-dark)] hover:text-[var(--color-accent-2)] hover:-translate-y-3 transition-all duration-500 ease-out"
>
Get in Touch
</a>
</div>
<WaveDivider fill="#0f0f0f" />
</section>
