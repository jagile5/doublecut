---
import WaveDivider from '../WaveDivider.astro';

const projects = [
{
title: 'Vancouver Gala Foundation',
category: 'Event · Video',
image: 'https://picsum.photos/seed/dc1/800/600',
},
{
title: 'Coast Mountain Aerials',
category: 'Aerial · Drone',
image: 'https://picsum.photos/seed/dc2/800/600',
},
{
title: 'Future Tech Product Launch',
category: 'CGI · VFX',
image: 'https://picsum.photos/seed/dc3/800/600',
},
];
---

<section class="grain-overlay py-24 md:py-32 px-6 bg-[var(--color-bg-dark)] relative overflow-hidden">
<div class="max-w-7xl mx-auto relative z-10">
<span data-animate="fade" class="font-body text-sm uppercase tracking-widest text-[var(--color-primary)] block mb-3 text-center">Our Work<span class="text-[var(--color-accent-1)] ml-1">.</span></span>
<h2 data-animate class="font-display text-6xl md:text-7xl text-white text-center mb-4">
Recent Work
</h2>
<p data-animate class="font-body text-white/50 text-center mb-14 max-w-2xl mx-auto">
A small sample of what we've been creating lately.
</p>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-stagger>
{projects.map(project => (
<a
href="/work"
data-stagger-item
data-animate
data-wiggle
class="group block rounded-2xl overflow-hidden bg-[#1a1a1a] hover:-translate-y-3 transition-all duration-700 ease-out"
>
<div class="aspect-[4/3] overflow-hidden relative">
<img
src={project.image}
alt={project.title}
loading="lazy"
class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700 ease-out"
/>
<span class="absolute top-3 left-3 px-3 py-1 bg-[var(--color-accent-1)] text-white font-body text-xs uppercase tracking-wider rounded-full">
{project.category}
</span>
</div>
<div class="p-5">
<h3 class="font-display text-2xl text-white mt-1">
{project.title}
</h3>
</div>
</a>
))}
</div>

<div data-animate class="text-center mt-12">
<a
href="/work"
class="inline-block px-6 py-3 border-2 border-[var(--color-primary)] text-[var(--color-primary)] font-display text-xl tracking-wider rounded-full hover:bg-[var(--color-primary)] hover:text-[var(--color-bg-dark)] hover:-translate-y-3 transition-all duration-700 ease-out"
>
See All Work &rarr;
</a>
</div>
</div>
<WaveDivider fill="#1e1e1e" />
</section>
