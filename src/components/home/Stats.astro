---
import WaveDivider from '../WaveDivider.astro';

const stats = [
{ value: '150+', label: 'Events Filmed', color: 'text-[var(--color-accent-2)]' },
{ value: '10+', label: 'Years Experience', color: 'text-[var(--color-accent-2)]' },
{ value: '4', label: 'Services, 1 Team', color: 'text-[var(--color-accent-2)]' },
{ value: '∞', label: 'Creative Ambition', color: 'text-[var(--color-accent-1)]' },
];
---

<section class="grain-overlay py-24 md:py-32 px-6 bg-[#1e1e1e] relative overflow-hidden">
<div class="max-w-7xl mx-auto relative z-20">
<div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12" data-stagger>
{stats.map(stat => (
<div
data-stagger-item
data-animate
data-wiggle
class="text-center bg-white/5 rounded-2xl py-8 px-4 hover:bg-white/10 hover:-translate-y-3 transition-all duration-500 ease-out"
style="border-color: rgba(255,255,255,0.05)"
>
<div class={`font-display text-5xl md:text-7xl leading-none mb-2 ${stat.color}`}>
{stat.value}
</div>
<div class="font-body text-sm md:text-base text-white/50 uppercase tracking-wider">
{stat.label}
</div>
</div>
))}
</div>
</div>
<WaveDivider fill="#F7F7F7" />
</section>
