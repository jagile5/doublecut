---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Double Cut Studios for event video, aerial, CGI, and photography services.">
  <section class="grain-overlay pt-32 pb-24 md:pb-32 px-6 bg-[var(--color-bg-dark)] min-h-screen relative overflow-hidden">
    <!-- Decorative teal blob — top right -->
    <div data-blob-drift class="absolute top-4 -right-12 w-[400px] h-[400px] pointer-events-none" aria-hidden="true">
      <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg" class="w-full h-full opacity-[0.04]">
        <path d="M250 50C340 20 450 100 470 220C490 340 400 450 280 470C160 490 50 400 30 280C10 160 160 80 250 50Z" fill="var(--color-primary)"/>
      </svg>
    </div>

    <!-- Decorative peach blob — bottom left -->
    <div data-blob-drift class="absolute bottom-4 -left-8 w-[350px] h-[350px] pointer-events-none" aria-hidden="true">
      <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg" class="w-full h-full opacity-[0.03]">
        <path d="M80 400C10 300 60 100 200 40C340 -20 490 80 490 220C490 360 380 490 240 490C100 490 150 500 80 400Z" fill="var(--color-accent-2)"/>
      </svg>
    </div>

    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 relative z-10">
      <!-- Left: heading + info -->
      <div>
        <span data-animate="fade" class="font-body text-sm uppercase tracking-widest text-[var(--color-primary)] block mb-3">Contact</span>
        <h1 data-animate class="font-display text-6xl md:text-8xl text-white mb-6" style="transition-delay: 0.1s">
          Let's Work<br />Together
        </h1>
        <p data-animate class="font-body text-white/60 text-lg leading-relaxed mb-10 max-w-md" style="transition-delay: 0.2s">
          Whether you need a full production team or a single specialist, we're ready. Tell us a bit about your project and we'll get back to you within 24 hours.
        </p>

        <div data-animate class="space-y-4" style="transition-delay: 0.3s">
          <div>
            <h3 class="font-display text-xl text-white mb-1">Email</h3>
            <a href="mailto:hello@doublecutstudios.com" class="font-body text-[var(--color-primary)] hover:underline">
              hello@doublecutstudios.com
            </a>
          </div>
          <div>
            <h3 class="font-display text-xl text-white mb-1">Social</h3>
            <div class="flex gap-4">
              <a href="#" class="font-body text-white/60 hover:text-[var(--color-primary)] transition-all duration-500 ease-out">Instagram</a>
              <a href="#" class="font-body text-white/60 hover:text-[var(--color-primary)] transition-all duration-500 ease-out">YouTube</a>
              <a href="#" class="font-body text-white/60 hover:text-[var(--color-primary)] transition-all duration-500 ease-out">LinkedIn</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div data-animate>
        <!-- Add Formspree action URL here -->
        <form action="#" method="POST" class="space-y-6">
          <div>
            <label for="name" class="block font-body text-sm text-white/70 mb-1">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full bg-white/5 border border-white/10 rounded-2xl px-4 py-3 text-white font-body placeholder-white/30 focus:outline-none focus:border-[var(--color-primary)] transition-all duration-500 ease-out"
              placeholder="Your name"
            />
          </div>

          <div>
            <label for="email" class="block font-body text-sm text-white/70 mb-1">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full bg-white/5 border border-white/10 rounded-2xl px-4 py-3 text-white font-body placeholder-white/30 focus:outline-none focus:border-[var(--color-primary)] transition-all duration-500 ease-out"
              placeholder="you@company.com"
            />
          </div>

          <div>
            <label for="phone" class="block font-body text-sm text-white/70 mb-1">Phone <span class="text-white/40">(optional)</span></label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full bg-white/5 border border-white/10 rounded-2xl px-4 py-3 text-white font-body placeholder-white/30 focus:outline-none focus:border-[var(--color-primary)] transition-all duration-500 ease-out"
              placeholder="+1 (555) 000-0000"
            />
          </div>

          <div>
            <label for="service" class="block font-body text-sm text-white/70 mb-1">Service</label>
            <select
              id="service"
              name="service"
              class="w-full bg-white/5 border border-white/10 rounded-2xl px-4 py-3 text-white font-body focus:outline-none focus:border-[var(--color-primary)] transition-all duration-500 ease-out appearance-none"
            >
              <option value="" class="bg-[var(--color-bg-dark)]">Select a service</option>
              <option value="event-video" class="bg-[var(--color-bg-dark)]">Event Videography</option>
              <option value="aerial-drone" class="bg-[var(--color-bg-dark)]">Aerial & Drone</option>
              <option value="vfx-cgi" class="bg-[var(--color-bg-dark)]">VFX & CGI</option>
              <option value="photography" class="bg-[var(--color-bg-dark)]">Photography</option>
            </select>
          </div>

          <div>
            <label for="message" class="block font-body text-sm text-white/70 mb-1">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full bg-white/5 border border-white/10 rounded-2xl px-4 py-3 text-white font-body placeholder-white/30 focus:outline-none focus:border-[var(--color-primary)] transition-all duration-500 ease-out resize-y"
              placeholder="Tell us about your project…"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full py-4 bg-[var(--color-primary)] text-[var(--color-bg-dark)] font-display text-xl tracking-wider rounded-full hover:shadow-[0_4px_20px_rgba(20,155,155,0.3)] hover:-translate-y-3 transition-all duration-500 ease-out"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
