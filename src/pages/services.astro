---
import BaseLayout from '../layouts/BaseLayout.astro';
import WaveDivider from '../components/WaveDivider.astro';

const services = [
{
id: 'event-videography',
title: 'Event Videography',
eyebrow: 'Service 01',
description: `We capture the energy and emotion of live events — the thunder of a thousand attendees, the quiet pride of a keynote, the chaos that somehow clicks into something beautiful on screen. From conferences and galas to product launches and weddings, we've filmed it all and we never phone it in.`,
deliverables: ['Same-day edits', 'Highlight reels', 'Multi-camera coverage', 'Interviews & testimonials'],
image: 'https://picsum.photos/seed/dc-svc-event/900/600',
reverse: false,
},
{
id: 'aerial-drone',
title: 'Aerial & Drone',
eyebrow: 'Service 02',
description: `Perspective changes everything. A sweeping location reveal, a dynamic tracking shot, the kind of B-roll that stops people mid-scroll — that's what aerial work does for a project. Our licensed operators plan every flight for maximum visual impact, safely and legally.`,
deliverables: ['Licensed drone operation', '4K aerial footage', 'Edited aerial sequences', 'Location scouting from the air'],
image: 'https://picsum.photos/seed/dc-svc-aerial/900/600',
reverse: true,
},
{
id: 'vfx-cgi',
title: 'VFX & CGI',
eyebrow: 'Service 03',
description: `Reality is just the starting point. Whether it's a photorealistic product render, a motion graphics package that makes a brand sing, or a fully built 3D environment — we take footage further. Our VFX work turns good shots into unforgettable ones.`,
deliverables: ['3D modelling & animation', 'Motion graphics', 'Compositing & VFX', 'Product renders & visualisations'],
image: 'https://picsum.photos/seed/dc-svc-cgi/900/600',
reverse: false,
},
{
id: 'photography',
title: 'Photography',
eyebrow: 'Service 04',
description: `Stills that work as hard as the video. We shoot event coverage, portraits, product, and brand lifestyle — always with an eye on how the images live alongside our motion work. Consistent tone. Consistent quality. No stock-photo energy.`,
deliverables: ['Event photography', 'Headshots & portraits', 'Product photography', 'Brand lifestyle shoots'],
image: 'https://picsum.photos/seed/dc-svc-photo/900/600',
reverse: true,
},
{
id: 'design-partners',
title: 'Design Partners',
eyebrow: 'Service 05',
description: `We don't do everything alone — and that's a strength, not a gap. When a project needs graphic design, we bring in trusted partners who share our standards. Brand identity, print collateral, social assets, packaging — seamlessly integrated with the production work.`,
deliverables: ['Brand identity (via partners)', 'Print & collateral design', 'Social media assets', 'Packaging design'],
image: 'https://picsum.photos/seed/dc-svc-design/900/600',
reverse: false,
},
];
---

<BaseLayout title="Services" description="Double Cut Studios services — event videography, aerial & drone, VFX & CGI, photography, and design partnerships.">
<!-- Page hero -->
<section class="grain-overlay pt-32 pb-16 md:pb-20 px-6 bg-[var(--color-bg-dark)] relative overflow-hidden">
<div class="max-w-7xl mx-auto text-center relative z-10">
<span data-animate="fade" class="font-body text-sm uppercase tracking-widest text-[var(--color-primary)] block mb-4">Our Services<span class="text-[var(--color-accent-1)] ml-1">.</span></span>
<h1 data-animate class="font-display text-6xl md:text-8xl text-white mb-6">What We Do</h1>
<p data-animate class="font-body text-white/50 text-lg max-w-xl mx-auto">
From intimate events to large-scale productions — we cover every angle.
</p>
</div>
<WaveDivider fill="#1e1e1e" />
</section>

<!-- Service sections -->
{services.map((service, i) => (
<section id={service.id} class={`grain-overlay py-24 md:py-32 px-6 relative overflow-hidden ${i % 2 === 0 ? 'bg-[var(--color-bg-dark)]' : 'bg-[#1e1e1e]'}`}>
<div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center relative z-10">
<!-- Image side -->
<div data-animate class={`overflow-hidden rounded-2xl ${service.reverse ? 'lg:order-2' : ''}`}>
<img
src={service.image}
alt={service.title}
loading="lazy"
class="w-full h-full object-cover hover:scale-[1.03] transition-transform duration-700 ease-out"
/>
</div>

<!-- Text side -->
<div class={service.reverse ? 'lg:order-1' : ''}>
<span data-animate="fade" class="font-body text-sm uppercase tracking-widest text-[var(--color-primary)] block mb-3">{service.eyebrow}</span>
<h2 data-animate class="font-display text-6xl md:text-7xl text-white mb-6">{service.title}</h2>
<p data-animate class="font-body text-white/60 text-base leading-relaxed mb-8">{service.description}</p>

<h3 data-animate="fade" class="font-display text-xl text-white/80 mb-3">Deliverables</h3>
<ul class="space-y-2 mb-8">
{service.deliverables.map(item => (
<li data-animate="fade" class="flex items-start gap-2 font-body text-sm text-white/50">
<svg class="w-4 h-4 text-[var(--color-primary)] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
<path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
</svg>
{item}
</li>
))}
</ul>

<a
href="/contact"
class="inline-block px-6 py-3 bg-[var(--color-primary)] text-[var(--color-bg-dark)] font-display text-lg tracking-wider rounded-full hover:shadow-[0_4px_20px_rgba(20,155,155,0.3)] hover:-translate-y-3 transition-all duration-500 ease-out"
>
Enquire &rarr;
</a>
</div>
</div>

{i < services.length - 1 && (
<WaveDivider fill={i % 2 === 0 ? '#1e1e1e' : '#262626'} />
)}
</section>
))}

<!-- Bottom CTA -->
<section class="grain-overlay py-24 md:py-32 px-6 bg-[var(--color-bg-dark)] relative overflow-hidden">
<div class="max-w-4xl mx-auto text-center relative z-10">
<h2 data-animate class="font-display text-5xl md:text-7xl mb-6" style="color: var(--color-accent-2);">
Ready to Make Something Great?
</h2>
<p data-animate class="font-body text-white/50 text-lg mb-10 max-w-xl mx-auto">
Whether it's a single shoot or a full creative campaign, we'd love to hear about your project.
</p>
<a
href="/contact"
data-animate
class="inline-block px-10 py-4 border-2 text-[var(--color-accent-2)] font-display text-2xl tracking-wider rounded-full hover:bg-[var(--color-accent-2)] hover:text-[var(--color-bg-dark)] hover:-translate-y-3 transition-all duration-500 ease-out"
style="border-color: var(--color-accent-2);"
>
Get in Touch
</a>
</div>
<WaveDivider fill="#0f0f0f" />
</section>
</BaseLayout>
