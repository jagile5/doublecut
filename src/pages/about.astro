---
import BaseLayout from '../layouts/BaseLayout.astro';

const values = [
  {
    title: 'Craft over shortcuts',
    description: 'We grew up caring about the details — the right light, the right cut, the right frame. That hasn\'t changed. We\'d rather take the time to do it properly than ship something we\'re not proud of.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.737-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.049.574.024 1.187-.14 1.737" /></svg>`,
  },
  {
    title: 'The best work is collaborative',
    description: 'You know your story better than anyone. We bring the technical skills, the creative instinct, and the gear. You bring the vision. Together, that\'s when things get interesting.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584P6.75 19.5l.001-.031m0 0a3 3 0 0 0-4.682-2.72 9.094 9.094 0 0 0 3.741.479M6.75 19.5a48.108 48.108 0 0 0 5.25.75m0 0V18a3 3 0 0 1 6 0v.75m-6 0a48.108 48.108 0 0 0 5.25.75" /></svg>`,
  },
  {
    title: 'Every story matters',
    description: 'From a 3-person startup launch to a 3,000-person gala — we show up the same way every time. Because the size of the audience doesn\'t determine the quality of the work.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>`,
  },
];

const process = [
  {
    step: '01',
    title: 'Listen First',
    description: 'Every project starts with a conversation. Tell us about your event, your brand, your vision — or just what you\'re trying to achieve. No brief required.',
  },
  {
    step: '02',
    title: 'Build the Right Team',
    description: 'We pull in exactly who the project needs — drone pilots, CGI artists, photographers, designers. You get a tailored crew, not a fixed package.',
  },
  {
    step: '03',
    title: 'Shoot & Create',
    description: 'We show up prepared and stay adaptable. Events are unpredictable by nature — we\'ve learned to love that.',
  },
  {
    step: '04',
    title: 'Deliver Something You\'re Proud Of',
    description: 'From rough cuts to final delivery, we keep you in the loop. The goal is work that makes you want to share it immediately.',
  },
];

const clients = ["Lululemon", "Vancouver Film Festival", "BC Tourism", "ConVancouver", "Harbour Events", "Pacific Brand Co."];
---

<BaseLayout title="About" description="Meet Double Cut Studios — a Vancouver-based production studio built on a love of craft, film, and the belief that every story deserves to be told well.">
  <!-- Hero -->
  <section class="pt-32 pb-16 md:pb-20 px-6 bg-[var(--color-bg-dark)] min-h-[60vh] flex items-center relative overflow-hidden">
    <div class="max-w-7xl mx-auto text-center relative z-20">
      <span data-animate-immediate="fade" data-delay="0" class="font-body text-sm uppercase tracking-widest text-[var(--color-primary)] block mb-4">About Us<span class="text-[var(--color-accent-1)] ml-1">.</span></span>
      <h1 data-animate-immediate data-delay="0.15" class="font-display text-6xl md:text-8xl text-white mb-6">
        We're Double Cut Studios
      </h1>
      <p data-animate-immediate data-delay="0.3" class="font-body text-white/60 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
        A Vancouver-based production studio built on a love of craft, a background in film, and the belief that every story — big or small — deserves to be told well.
      </p>
    </div>
  </section>

  <!-- Our Story — light section -->
  <section class="pt-28 md:pt-36 pb-28 md:pb-36 px-6 bg-warm-light relative overflow-hidden">
    <!-- Wave top — dark→light transition from hero above -->
    <div class="absolute top-0 left-0 w-full pointer-events-none z-20" aria-hidden="true">
      <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto block" preserveAspectRatio="none">
        <path d="M0 40C240 0 480 80 720 40C960 0 1200 80 1440 40V0H0V40Z" fill="var(--color-bg-dark)"/>
      </svg>
    </div>
    <!-- Decorative peach blob — right side -->
    <div data-blob-drift class="absolute top-20 -right-8 w-[400px] h-[400px] pointer-events-none" aria-hidden="true">
      <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg" class="w-full h-full opacity-[0.04]">
        <path d="M400 100C460 200 420 380 300 440C180 500 40 400 20 280C0 160 80 40 200 20C320 0 340 0 400 100Z" fill="var(--color-accent-2)"/>
      </svg>
    </div>

    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center relative z-10">
      <div>
        <span data-animate="fade" class="font-body text-sm uppercase tracking-widest text-[var(--color-primary)] block mb-3">Our Story<span class="text-[var(--color-accent-1)] ml-1">.</span></span>
        <h2 data-animate class="font-display text-6xl md:text-7xl text-[var(--color-bg-dark)] mb-6">
          How We Got Here
        </h2>
        <p data-animate class="font-body text-[var(--color-text-dark)]/70 text-base leading-relaxed mb-4">
          Double Cut Studios started with a camera, a film degree, and a one-way ticket from New Zealand to Vancouver. Josh grew up obsessed with the way stories move — the way a well-timed cut can change how something feels, or how a single aerial shot can reframe an entire place. He studied film in New Zealand, spent years shooting everything he could get his hands on, and eventually landed in Vancouver with a drive to build something.
        </p>
        <p data-animate class="font-body text-[var(--color-text-dark)]/70 text-base leading-relaxed">
          What started as one person and a kit bag has grown into a full-service studio. We bring in the right people for every project — drone pilots, CGI artists, photographers, designers — so you always get a tailored team without the agency overhead. Small enough to care deeply about every frame. Experienced enough to handle whatever you throw at us.
        </p>
      </div>
      <div data-animate class="overflow-hidden rounded-2xl">
        <img
          src="https://picsum.photos/seed/dc-about/900/700"
          alt="Double Cut Studios team at work"
          loading="lazy"
          class="w-full h-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- What We Believe — dark section -->
  <section class="pt-28 md:pt-36 pb-28 md:pb-36 px-6 bg-[var(--color-bg-dark)] relative overflow-hidden">
    <!-- Wave top — light→dark transition from story section above -->
    <div class="absolute top-0 left-0 w-full pointer-events-none z-20" aria-hidden="true">
      <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto block" preserveAspectRatio="none">
        <path d="M0 50C360 10 720 70 1080 30C1260 15 1380 55 1440 50V0H0V50Z" fill="var(--color-bg-light)"/>
      </svg>
    </div>

    <!-- Decorative teal blob — right side -->
    <div data-blob-drift class="absolute top-4 -right-12 w-[400px] h-[400px] pointer-events-none" aria-hidden="true">
      <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg" class="w-full h-full opacity-[0.04]">
        <path d="M250 50C340 20 450 100 470 220C490 340 400 450 280 470C160 490 50 400 30 280C10 160 160 80 250 50Z" fill="var(--color-primary)"/>
      </svg>
    </div>
    <!-- Decorative peach blob — left bottom -->
    <div data-blob-drift class="absolute bottom-4 -left-8 w-[300px] h-[300px] pointer-events-none" aria-hidden="true">
      <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg" class="w-full h-full opacity-[0.03]">
        <path d="M80 400C10 300 60 100 200 40C340 -20 490 80 490 220C490 360 380 490 240 490C100 490 150 500 80 400Z" fill="var(--color-accent-2)"/>
      </svg>
    </div>

    <div class="max-w-7xl mx-auto relative z-10">
      <span data-animate="fade" class="font-body text-sm uppercase tracking-widest text-[var(--color-primary)] block mb-3 text-center">Our Values<span class="text-[var(--color-accent-1)] ml-1">.</span></span>
      <h2 data-animate class="font-display text-6xl md:text-7xl text-white text-center mb-14">
        What We Believe
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-stagger>
        {values.map(value => (
        <div
          data-stagger-item
          data-animate
          data-wiggle
          class="bg-white/5 rounded-2xl p-8 hover:bg-white/10 transition-all duration-500 ease-out"
          style="border: 1px solid rgba(255,255,255,0.05)"
        >
          <div class="text-[var(--color-primary)] mb-4" set:html={value.icon} />
          <h3 class="font-display text-2xl text-white mb-3">{value.title}</h3>
          <p class="font-body text-white/60 text-sm leading-relaxed">{value.description}</p>
        </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How We Work — light section -->
  <section class="pt-28 md:pt-36 pb-28 md:pb-36 px-6 bg-warm-light relative overflow-hidden">
    <!-- Wave top — dark→light transition from values section above -->
    <div class="absolute top-0 left-0 w-full pointer-events-none z-20" aria-hidden="true">
      <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto block" preserveAspectRatio="none">
        <path d="M0 50C360 10 720 70 1080 30C1260 15 1380 55 1440 50V0H0V50Z" fill="var(--color-bg-dark)"/>
      </svg>
    </div>

    <!-- Decorative peach blob — left side -->
    <div data-blob-drift class="absolute top-40 -left-8 w-[350px] h-[350px] pointer-events-none" aria-hidden="true">
      <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg" class="w-full h-full opacity-[0.04]">
        <path d="M80 400C10 300 60 100 200 40C340 -20 490 80 490 220C490 360 380 490 240 490C100 490 150 500 80 400Z" fill="var(--color-accent-2)"/>
      </svg>
    </div>
    <!-- Decorative teal blob — right side -->
    <div data-blob-drift class="absolute top-4 -right-8 w-[300px] h-[300px] pointer-events-none" aria-hidden="true">
      <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg" class="w-full h-full opacity-[0.03]">
        <path d="M400 100C460 200 420 380 300 440C180 500 40 400 20 280C0 160 80 40 200 20C320 0 340 0 400 100Z" fill="var(--color-primary)"/>
      </svg>
    </div>

    <div class="max-w-7xl mx-auto relative z-10">
      <span data-animate="fade" class="font-body text-sm uppercase tracking-widest text-[var(--color-primary)] block mb-3 text-center">The Process<span class="text-[var(--color-accent-1)] ml-1">.</span></span>
      <h2 data-animate class="font-display text-6xl md:text-7xl text-[var(--color-bg-dark)] text-center mb-14">
        How We Work
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8" data-stagger>
        {process.map(p => (
        <div
          data-stagger-item
          data-animate
          data-wiggle
          class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-md hover:-translate-y-3 transition-all duration-500 ease-out"
        >
          <span class="font-display text-5xl text-[var(--color-accent-1)]/20 block mb-4">{p.step}</span>
          <h3 class="font-display text-2xl text-[var(--color-bg-dark)] mb-3">{p.title}</h3>
          <p class="font-body text-[var(--color-text-dark)]/60 text-sm leading-relaxed">{p.description}</p>
        </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Trusted By — dark section -->
  <section class="pt-28 md:pt-36 pb-20 md:pb-28 px-6 bg-[var(--color-bg-dark)] relative overflow-hidden">
    <!-- Wave top — light→dark transition from process section above -->
    <div class="absolute top-0 left-0 w-full pointer-events-none z-20" aria-hidden="true">
      <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto block" preserveAspectRatio="none">
        <path d="M0 50C360 10 720 70 1080 30C1260 15 1380 55 1440 50V0H0V50Z" fill="var(--color-bg-light)"/>
      </svg>
    </div>

    <!-- Decorative teal blob — left bottom -->
    <div data-blob-drift class="absolute bottom-4 -left-8 w-[300px] h-[300px] pointer-events-none" aria-hidden="true">
      <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg" class="w-full h-full opacity-[0.03]">
        <path d="M50 250C20 160 100 50 220 30C340 10 450 100 470 220C490 340 400 450 280 470C160 490 80 340 50 250Z" fill="var(--color-primary)"/>
      </svg>
    </div>
    <!-- Decorative peach blob — right top -->
    <div data-blob-drift class="absolute top-4 -right-4 w-[250px] h-[250px] pointer-events-none" aria-hidden="true">
      <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg" class="w-full h-full opacity-[0.03]">
        <path d="M400 100C460 200 420 380 300 440C180 500 40 400 20 280C0 160 80 40 200 20C320 0 340 0 400 100Z" fill="var(--color-accent-2)"/>
      </svg>
    </div>

    <div class="max-w-7xl mx-auto relative z-10">
      <span data-animate="fade" class="font-body text-sm uppercase tracking-widest text-[var(--color-primary)] block mb-3 text-center">Our Clients<span class="text-[var(--color-accent-1)] ml-1">.</span></span>
      <h2 data-animate class="font-display text-5xl md:text-6xl text-white text-center mb-10">
        Trusted By
      </h2>
      <div data-animate class="flex flex-wrap gap-4 justify-center opacity-60">
        {clients.map(name => (
        <span
          class="rounded-full px-6 py-2.5 text-sm tracking-wide text-white/70 font-body hover:text-white hover:border-[var(--color-primary)] transition-colors duration-500 ease-out"
          style="border: 1px solid rgba(255,255,255,0.2)"
        >
          {name}
        </span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA — dark bg, peach heading, outline button -->
  <section class="pt-28 md:pt-36 pb-28 md:pb-36 px-6 bg-[var(--color-bg-dark)] relative overflow-hidden">
    <!-- Decorative peach blob -->
    <div data-blob-drift class="absolute top-1/2 -left-8 w-[450px] h-[450px] pointer-events-none" aria-hidden="true">
      <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg" class="w-full h-full opacity-[0.04]">
        <path d="M100 400C20 300 40 120 180 60C320 0 480 80 490 220C500 360 380 480 240 490C100 500 180 500 100 400Z" fill="var(--color-accent-2)"/>
      </svg>
    </div>
    <!-- Decorative teal blob -->
    <div data-blob-drift class="absolute top-4 -right-8 w-[300px] h-[300px] pointer-events-none" aria-hidden="true">
      <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg" class="w-full h-full opacity-[0.03]">
        <path d="M250 50C340 20 450 100 470 220C490 340 400 450 280 470C160 490 50 400 30 280C10 160 160 80 250 50Z" fill="var(--color-primary)"/>
      </svg>
    </div>

    <div class="max-w-4xl mx-auto text-center relative z-10">
      <h2 data-animate class="font-display text-5xl md:text-7xl mb-6" style="color: var(--color-accent-2);">
        Got a project in mind?
      </h2>
      <p data-animate class="font-body text-white/50 text-lg mb-10 max-w-xl mx-auto">
        We'd love to hear about it. No brief required — just start a conversation.
      </p>
      <a
        href="/contact"
        data-animate
        class="inline-block px-10 py-4 border-2 text-[var(--color-accent-2)] font-display text-2xl tracking-wider rounded-full hover:bg-[var(--color-accent-2)] hover:text-[var(--color-bg-dark)] hover:-translate-y-3 transition-all duration-500 ease-out"
        style="border-color: var(--color-accent-2);"
      >
        Let's Talk
      </a>
    </div>
  </section>
</BaseLayout>
