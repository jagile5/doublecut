---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import Marquee from '../components/Marquee.astro';
import Services from '../components/home/Services.astro';
import PortfolioPreview from '../components/home/PortfolioPreview.astro';
import Stats from '../components/home/Stats.astro';
import Testimonials from '../components/home/Testimonials.astro';
import HomeCTA from '../components/home/HomeCTA.astro';
---

<BaseLayout title="Home" description="Double Cut Studios — Full-service creative production. Event Video, Aerial, VFX/CGI, Photography.">
  <Hero />
  <Marquee items={["Event Videography & Cinematic Coverage", "Aerial & Drone Piloting", "VFX & CGI Production", "Photography & Visual Storytelling", "Vancouver BC — Based", "New Zealand Born & Raised", "Double Cut Studios — Telling Your Story"]} speed={60} />
  <Services />
  <PortfolioPreview />
  <Marquee items={["150+ Events Filmed Worldwide", "4K Cinematic Footage", "Licensed Drone Operations", "3D Animation & Modelling", "Motion Graphics & VFX", "Professional Colour Grading", "Immersive Sound Design"]} speed={80} reverse={true} />
  <Stats />
  <Testimonials />
  <HomeCTA />
</BaseLayout>
